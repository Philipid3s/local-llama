# Copy values from here into .env if needed.
PORT=3000
OLLAMA_BASE_URL=http://localhost:11434
OCR_ENABLED=true
OCR_LANG=eng
OCR_MAX_PAGES=3
OCR_MIN_TEXT_CHARS=80
OCR_IMAGE_SCALE=2
BRAVE_SEARCH_ENABLED=false
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_MAX_RESULTS=5
BRAVE_SEARCH_COUNTRY=US
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Backward-compatible alias:
# OLLAMA_EMBED_MODEL=nomic-embed-text
DEFAULT_VECTOR_INSTANCE_ID=default
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000
CHROMA_SSL=false
CHROMA_COLLECTION=bonsai_documents
VECTOR_DB_INSTANCES=
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=180
RAG_RETRIEVAL_LIMIT=4
RAG_QUERY_CANDIDATE_LIMIT=12
RAG_MAX_CONTEXT_CHARS_PER_EXCERPT=1600
EMBED_BATCH_SIZE=16
RAG_UPSERT_BATCH_SIZE=5000
DEVOPS_TICKET_MAX_RECORD_CHARS=5000
