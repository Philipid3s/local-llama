# Copy the variables you need from this file into `.env`.
# The entries below are sorted alphabetically for easier scanning.

# BRAVE_SEARCH_API_KEY
# API key used when Brave web search is enabled.
# Leave empty if `BRAVE_SEARCH_ENABLED=false`.
BRAVE_SEARCH_API_KEY=

# BRAVE_SEARCH_COUNTRY
# Country code sent to Brave Search to localize result ranking.
# Typical values are `US`, `SG`, `GB`, etc.
BRAVE_SEARCH_COUNTRY=US

# BRAVE_SEARCH_ENABLED
# Enables live Brave Search lookups for current events, recent facts, and web results.
# Set to `false` if you want the app to rely only on the model and local knowledge base.
BRAVE_SEARCH_ENABLED=false

# BRAVE_SEARCH_MAX_RESULTS
# Maximum number of Brave Search results fetched for a single web search request.
# Higher values provide broader coverage but increase latency and prompt size.
BRAVE_SEARCH_MAX_RESULTS=5

# CHROMA_COLLECTION
# Collection name inside Chroma where knowledge-base chunks are stored.
# Change this if you want to isolate one dataset from another in the same Chroma server.
CHROMA_COLLECTION=bonsai_documents

# CHROMA_HOST
# Hostname or IP address of the Chroma server used for persistent vector storage.
CHROMA_HOST=127.0.0.1

# CHROMA_PORT
# Network port exposed by the Chroma server.
CHROMA_PORT=8000

# CHROMA_SSL
# Whether the app should connect to Chroma over HTTPS.
# Use `true` only when your Chroma endpoint is configured for TLS.
CHROMA_SSL=false

# DEFAULT_VECTOR_INSTANCE_ID
# Default vector instance selected in the UI when multiple vector instances are configured.
# This must match one of the instance IDs defined in `VECTOR_DB_INSTANCES`.
DEFAULT_VECTOR_INSTANCE_ID=default

# DEVOPS_TICKET_MAX_RECORD_CHARS
# Maximum character length for a single indexed DevOps ticket record before it is split into multiple chunks.
# Larger values preserve more ticket context per chunk but increase embedding and retrieval payload size.
DEVOPS_TICKET_MAX_RECORD_CHARS=5000

# EMBED_BATCH_SIZE
# Number of text chunks sent to the embedding model in one batch request.
# Larger batches can improve throughput but may increase memory usage or timeout risk.
EMBED_BATCH_SIZE=16

# OCR_ENABLED
# Enables OCR fallback for PDFs when normal text extraction returns too little text.
# Disable this if you do not want image-based text extraction.
OCR_ENABLED=true

# OCR_IMAGE_SCALE
# Image scaling factor used before OCR.
# Higher values usually improve OCR quality but make processing slower and heavier.
OCR_IMAGE_SCALE=2

# OCR_LANG
# OCR language code passed to Tesseract.
# Use a language installed and supported by your OCR setup.
OCR_LANG=eng

# OCR_MAX_PAGES
# Maximum number of PDF pages processed with OCR fallback.
# This limits OCR cost on large scanned PDFs.
OCR_MAX_PAGES=3

# OCR_MIN_TEXT_CHARS
# Minimum extracted text length before the app decides OCR fallback is needed.
# If normal extraction returns fewer characters than this threshold, OCR is attempted.
OCR_MIN_TEXT_CHARS=80

# OLLAMA_BASE_URL
# Base URL of the Ollama server used for chat generation and embeddings.
OLLAMA_BASE_URL=http://localhost:11434

# OLLAMA_EMBEDDING_MODEL
# Ollama embedding model used to create vectors for indexed documents and user queries.
# This is the preferred variable name used by the current code.
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# OLLAMA_EMBED_MODEL
# Backward-compatible alias for `OLLAMA_EMBEDDING_MODEL`.
# Keep this commented unless you need compatibility with older setups.
# OLLAMA_EMBED_MODEL=nomic-embed-text

# PORT
# Port used by the local Node server that serves the application UI and API.
PORT=3000

# RAG_CHUNK_OVERLAP
# Number of overlapping characters kept between adjacent text chunks during ingestion.
# Overlap helps preserve context when a relevant passage spans a chunk boundary.
RAG_CHUNK_OVERLAP=180

# RAG_CHUNK_SIZE
# Approximate chunk size, in characters, used when splitting extracted text for indexing.
# Larger chunks preserve more context; smaller chunks can improve retrieval precision.
RAG_CHUNK_SIZE=1200

# RAG_MAX_CONTEXT_CHARS_PER_EXCERPT
# Maximum number of characters from a retrieved chunk inserted into the final model prompt.
# Long excerpts are compressed to stay under prompt and GPU memory limits.
RAG_MAX_CONTEXT_CHARS_PER_EXCERPT=1600

# RAG_QUERY_CANDIDATE_LIMIT
# Number of vector-search candidates fetched before local reranking is applied.
# Increasing this can improve recall for difficult queries but also increases latency.
RAG_QUERY_CANDIDATE_LIMIT=12

# RAG_RETRIEVAL_LIMIT
# Final number of retrieved chunks added to a chat request after reranking and selection.
RAG_RETRIEVAL_LIMIT=4

# RAG_UPSERT_BATCH_SIZE
# Number of chunk records sent to Chroma per upsert batch during ingestion.
# Reduce this if Chroma or the network struggles with large write payloads.
RAG_UPSERT_BATCH_SIZE=5000

# VECTOR_DB_INSTANCES
# Optional JSON array of named vector database instances shown in the UI selector.
# Leave empty to use the single default Chroma instance defined by the `CHROMA_*` variables above.
# Example:
# VECTOR_DB_INSTANCES=[{"id":"default","name":"Vector:Chroma:1","host":"127.0.0.1","port":8000,"ssl":false,"collection":"bonsai_documents"}]
VECTOR_DB_INSTANCES=
